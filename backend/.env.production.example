NODE_ENV=production
PORT=4010
# Optional. Leave empty if the hosting provider manages the bind host.
HOST=0.0.0.0

# Public domains
CORS_ORIGIN=https://aktyor.az
PUBLIC_BASE_URL=https://aktyor.az
SITEMAP_BASE_URL=https://aktyor.az
UPLOAD_BASE_URL=https://aktyor.az

# Persistent storage
DATABASE_PATH=/var/lib/aktyoraz/data/aktyor.sqlite
UPLOAD_DIR=/var/lib/aktyoraz/uploads

# PDF fonts. Use real font paths on the production server.
PDF_FONT_REGULAR=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
PDF_FONT_BOLD=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf

# Security. Replace every value before deploy.
JWT_SECRET=replace-with-at-least-64-random-characters
ADMIN_EMAIL=admin@aktyor.az
ADMIN_PASSWORD=replace-with-a-strong-production-password
ADMIN_NAME=Aktyor.az Admin
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_LOGIN_RATE_LIMIT_MAX=5

# AI casting. Keep this only on the backend server.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
